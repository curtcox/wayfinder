{
  "rules": [
    {
      "match": {
        "goal_status": "pending",
        "open_recommendation_id": {"$null": true}
      },
      "recommendation": {
        "recommendation_type": "action",
        "summary": "Fetch remote status JSON into the workspace.",
        "goal_status": "running",
        "confidence": 0.85,
        "action": {
          "kind": "shell",
          "title": "curl status endpoint",
          "shell": {
            "argv": [
              "curl",
              "-fsS",
              "https://example.com/v1/status",
              "-o",
              "status.json"
            ],
            "command_for_display": "curl -fsS https://example.com/v1/status -o status.json",
            "cwd": "{workspace_uri}",
            "env": {"mode": "minimal", "set": {}},
            "stdin": {"mode": "none"},
            "pty": false,
            "timeout_seconds": 60,
            "expected_exit_codes": [0],
            "requires_shell": false
          },
          "preconditions": [],
          "success_criteria": []
        },
        "idempotency": {
          "level": "strong",
          "key": "idem_{goal_id}_curl",
          "scope": "workspace",
          "safe_to_retry": true,
          "safe_to_run_if_already_done": true,
          "detects_noop": false,
          "dedupe_strategy": "idempotency_key",
          "partial_failure_recovery": "retry",
          "max_attempts": 1
        },
        "risk": {
          "level": "medium",
          "classes": ["network_read", "write_workspace"],
          "blast_radius": "workspace",
          "requires_approval": true,
          "destructive": false,
          "network": "required",
          "secrets": "not_required",
          "rollback": {"available": false, "kind": "unknown", "instructions": null}
        }
      }
    }
  ]
}
