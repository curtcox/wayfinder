{
  "rules": [
    {
      "match": {
        "goal_status": "pending",
        "open_recommendation_id": {"$null": true}
      },
      "recommendation": {
        "recommendation_type": "action",
        "summary": "Emit output larger than the inline limit.",
        "goal_status": "running",
        "confidence": 0.9,
        "action": {
          "kind": "shell",
          "title": "Large stdout",
          "shell": {
            "argv": ["python3", "-c", "print('x' * 12000)"],
            "command_for_display": "python3 -c \"print('x' * 12000)\"",
            "cwd": "{workspace_uri}",
            "env": {"mode": "minimal", "set": {}},
            "stdin": {"mode": "none"},
            "pty": false,
            "timeout_seconds": 60,
            "expected_exit_codes": [0],
            "requires_shell": false
          },
          "preconditions": [],
          "success_criteria": []
        },
        "idempotency": {
          "level": "strong",
          "key": "idem_{goal_id}_large_stdout",
          "scope": "workspace",
          "safe_to_retry": true,
          "safe_to_run_if_already_done": true,
          "detects_noop": false,
          "dedupe_strategy": "idempotency_key",
          "partial_failure_recovery": "retry",
          "max_attempts": 1
        },
        "risk": {
          "level": "low",
          "classes": ["execute_local"],
          "blast_radius": "workspace",
          "requires_approval": false,
          "destructive": false,
          "network": "not_required",
          "secrets": "not_required",
          "rollback": {"available": false, "kind": "unknown", "instructions": null}
        }
      }
    },
    {
      "match": {
        "completed_steps": {"$gte": 1},
        "open_recommendation_id": {"$null": true}
      },
      "recommendation": {
        "recommendation_type": "done",
        "summary": "Large output captured.",
        "goal_status": "running",
        "confidence": 0.95,
        "done": {"reason": "Large stdout spilled to an artifact."}
      }
    }
  ]
}
